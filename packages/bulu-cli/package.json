{
  "name": "@bulu-cli/core",
  "description": "CLI for local Ethereum/Tron wallets, signing policies, and Hyperliquid trading",
  "type": "module",
  "version": "0.0.8",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enpitsuLin/bulu-cli.git",
    "directory": "packages/bulu-cli"
  },
  "bin": {
    "bulu": "./dist/index.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">= 24.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.1.0",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@bulu-cli/tcx-core": "workspace:*",
    "@clack/prompts": "^1.5.0",
    "@msgpack/msgpack": "^3.1.3",
    "citty": "^0.2.2",
    "console-table-printer": "^2.16.0",
    "defu": "^6.1.7",
    "ofetch": "^1.5.1",
    "unctx": "^2.5.0",
    "uqr": "^0.1.3",
    "viem": "^2.52.0"
  }
}
