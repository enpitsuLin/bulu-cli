{
  "name": "@bulu-cli/core",
  "description": "CLI for managing local Ethereum and Tron wallets",
  "type": "module",
  "version": "0.0.6",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enpitsuLin/bulu-cli.git",
    "directory": "packages/bulu-cli"
  },
  "bin": {
    "bulu": "./dist/index.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@bulu-cli/tcx-core": "workspace:*",
    "@clack/prompts": "^1.2.0",
    "@msgpack/msgpack": "^3.1.3",
    "@noble/hashes": "^2.2.0",
    "citty": "^0.2.2",
    "console-table-printer": "^2.15.0",
    "defu": "^6.1.7",
    "ofetch": "^1.5.1",
    "unctx": "^2.5.0",
    "uqr": "^0.1.3"
  }
}
