{
  "name": "@bulu-cli/monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build",
    "format": "pnpm run \"/^format:.*/\"",
    "format:prettier": "prettier . -w",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:oxlint": "oxlint .",
    "lint:rs": "cargo clippy -p bulu_cli_tcx_core --all-targets",
    "test": "pnpm --filter \"./packages/*\" run test",
    "bump": "node scripts/bump-version.mjs",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@taplo/cli": "^0.7.0",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint --fix"
    ],
    "*.@(js|ts|tsx|yml|yaml|md|json)": [
      "prettier --write"
    ],
    "*.toml": [
      "taplo format"
    ],
    "*.rs": [
      "rustfmt"
    ]
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  }
}
